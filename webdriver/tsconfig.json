{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["@wdio/globals/types", "expect-webdriverio", "@wdio/mocha-framework", "node"]
  },
  "include": ["wdio.conf.ts", "test/**/*.ts"]
}
