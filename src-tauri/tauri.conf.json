{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mission Editor",
  "version": "0.1.0",
  "identifier": "com.tom.missioneditor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mission Editor",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/TomsBack/MissionEditor/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQwNzlFRjFFRDhDNjIxMQpSV1FSWW96dDhaNEhCTDkyeGNMZzArRE5xU2NZZE5GQjQwd0ZtOUhaT3g3VTc2bk1taFNMR3EyRgo="
    }
  }
}
